# .env.local (Step 25 — Final)
# Maa Flavours — Complete Environment Variables Reference
# Copy to .env.local, fill in all values, NEVER commit to git

# ═══════════════════════════════════════════════════════════════
#  SUPABASE
# ═══════════════════════════════════════════════════════════════
# Get from: Supabase Dashboard → Project → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ═══════════════════════════════════════════════════════════════
#  RAZORPAY
# ═══════════════════════════════════════════════════════════════
# Get from: Razorpay Dashboard → Settings → API Keys
# Use rzp_test_ keys for testing, rzp_live_ for production
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret_here
# Public key — safe to expose to browser
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx

# ═══════════════════════════════════════════════════════════════
#  TWILIO (OTP AUTHENTICATION)
# ═══════════════════════════════════════════════════════════════
# Get from: Twilio Console → Account Info
# Create a Verify Service at: console.twilio.com/us1/verify/services
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ═══════════════════════════════════════════════════════════════
#  ADMIN PANEL
# ═══════════════════════════════════════════════════════════════
# Admin login credentials
ADMIN_EMAIL=admin@maaflavours.com

# Generate hash: node -e "const b=require('bcryptjs'); console.log(b.hashSync('YourPassword123!',12));"
ADMIN_PASSWORD_HASH=$2a$12$xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# JWT secret for admin session tokens (32+ random bytes)
# Generate: openssl rand -base64 32
ADMIN_JWT_SECRET=your_random_32_byte_secret_base64_encoded_here

# ═══════════════════════════════════════════════════════════════
#  SITE CONFIGURATION
# ═══════════════════════════════════════════════════════════════
NEXT_PUBLIC_SITE_URL=https://maaflavours.com
NEXT_PUBLIC_SITE_NAME=Maa Flavours
NEXT_PUBLIC_CURRENCY=INR
NEXT_PUBLIC_CURRENCY_SYMBOL=\u20b9

# WhatsApp widget number (no + or spaces, include country code)
NEXT_PUBLIC_WHATSAPP_NUMBER=919876543210

# ═══════════════════════════════════════════════════════════════
#  OPTIONAL — EMAIL NOTIFICATIONS
# ═══════════════════════════════════════════════════════════════
# Uncomment and fill to enable email order confirmations
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=orders@maaflavours.com
# SMTP_PASS=your_gmail_app_password_here

# ═══════════════════════════════════════════════════════════════
#  OPTIONAL — ANALYTICS
# ═══════════════════════════════════════════════════════════════
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
